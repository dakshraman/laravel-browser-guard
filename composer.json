{
    "name": "dakshraman/laravel-browser-guard",
    "description": "A Laravel package to discourage right-click, shortcut keys, and casual DevTools access in the browser.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "dakshraman",
            "email": "ramandaksh6161@gmail.com"
        }
    ],
    "keywords": [
        "laravel",
        "browser",
        "guard",
        "right-click",
        "devtools",
        "shortcuts"
    ],
    "require": {
        "php": "^7.1.3|^8.0",
        "illuminate/support": "^5.8|^6.0|^7.0|^8.0|^9.0|^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Dakshraman\\BrowserGuard\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Dakshraman\\BrowserGuard\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Dakshraman\\BrowserGuard\\BrowserGuardServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "pestphp/pest": "^2.0|^3.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0|^4.0"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
